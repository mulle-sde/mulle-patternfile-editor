{
  "name": "mulle-patternfile-editor",
  "version": "0.0.2",
  "description": "🧶 GUI App to edit mulle-match pattern files",
  "main": "main.js",
  "bin": {
    "mulle-patternfile-editor": "cli.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mulle-sde/mulle-patternfile-editor.git"
  },
  "scripts": {
    "start": "electron . --no-sandbox",
    "dev": "electron . --no-sandbox --inspect",
    "build": "electron-builder",
    "build-linux": "electron-builder --linux",
    "build-mac": "electron-builder --mac",
    "build-win": "electron-builder --win",
    "build-all": "electron-builder --linux --mac --win",
    "dist": "electron-builder --publish=never",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
    "format": "npx eslint *.js --fix"
  },
  "build": {
    "appId": "com.mulle-kybernetik.patternfile-editor",
    "productName": "mulle-patternfile-editor",
    "publish": [
      {
        "provider": "github",
        "releaseType": "release",
        "vPrefixedTagName": false
      }
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "cli.js",
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "styles.css",
      "icon.svg",
      "icon.png",
      "icon-512.png"
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development",
      "icon": "icon-512.png",
      "description": "🧶 GUI App to edit mulle-match pattern files",
      "executableName": "mulle-patternfile-editor"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "icon": "icon-512.png"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon-512.png"
    }
  },
  "keywords": [
    "mulle-sde",
    "mulle-match",
    "pattern-editor",
    "electron"
  ],
  "author": {
    "name": "Mulle kybernetiK",
    "email": "nat@mulle-kybernetik.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mulle-sde/mulle-patternfile-editor.git"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^40.4.1",
    "electron-builder": "^26.7.0",
    "eslint": "^8.57.1",
    "eslint-plugin-align-assignments": "^1.1.2"
  }
}
